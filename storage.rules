rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Stories: any authenticated user can upload to their own folder
    // Public read so story images can be viewed without auth
    match /stories/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
