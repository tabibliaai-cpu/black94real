{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "black94",
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/download-keystore.html",
        "destination": "/download-keystore.html"
      },
      {
        "source": "/black94-release.jks",
        "destination": "/black94-release.jks"
      },
      {
        "source": "/black94.aab",
        "destination": "/black94.aab"
      },
      {
        "source": "/black94-keystore.zip",
        "destination": "/black94-keystore.zip"
      },
      {
        "source": "/black94-release.keystore",
        "destination": "/black94-release.keystore"
      },
      {
        "source": "/privacy-policy.html",
        "destination": "/privacy-policy.html"
      },
      {
        "source": "/terms-of-service.html",
        "destination": "/terms-of-service.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/black94.aab",
        "headers": [
          {
            "key": "Content-Disposition",
            "value": "attachment; filename=\"black94.aab\""
          },
          {
            "key": "Content-Type",
            "value": "application/octet-stream"
          }
        ]
      },
      {
        "source": "/black94-release.keystore",
        "headers": [
          {
            "key": "Content-Disposition",
            "value": "attachment; filename=\"black94-release.keystore\""
          },
          {
            "key": "Content-Type",
            "value": "application/octet-stream"
          }
        ]
      },
      {
        "source": "/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ]
  }
}
